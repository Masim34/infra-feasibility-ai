# ============================================================
# infra-feasibility-ai - Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit your .env file to version control
# ============================================================

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=infraai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://postgres:your-postgres-password@localhost:5432/infraai

# ElectricityMap API (optional - for live grid carbon intensity)
# Get free key at: https://app.electricitymaps.com/
ELECTRICITYMAP_API_KEY=

# Anthropic Claude API (optional - for AI report generation)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API (optional - alternative LLM)
OPENAI_API_KEY=

# Redis Cache (optional - for production caching)
REDIS_URL=redis://localhost:6379

# Environment
ENVIRONMENT=development
DEBUG=true

# pgAdmin (when using docker-compose --profile admin)
PGADMIN_EMAIL=admin@infra-ai.com
PGADMIN_PASSWORD=admin

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2

# Cache TTL (hours)
CACHE_TTL_HOURS=24
